# Configuration des URLs et ports — modifie ces valeurs sans toucher au code

# Serveur Node.js (Express + Socket.IO)
# Si VITE_SERVER_HOST est vide, on utilise window.location.hostname (utile depuis téléphone)
VITE_SERVER_HOST=
VITE_SERVER_PORT=3000

# Serveur Python : API commandes (POST /command/register, WS /command, /data)
VITE_VIDEO_HOST=100.81.175.3
VITE_VIDEO_PORT=8002

# Serveur Python : streams MJPEG (/stream/raw, /stream/annotated)
VITE_STREAM_HOST=100.81.175.3
