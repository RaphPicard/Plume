# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=plume
PG_USER=postgres
PG_PASSWORD=postgres

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Clé de signature des JWT utilisateurs/admins — changer en prod
JWT_SECRET=dev-secret
# Secret partagé entre le serveur et les Raspberry Pi pour obtenir un token cart
CART_SECRET=cart-dev-secret

CAMERA_SECRET=cart-dev-secret
CAMERA_WS_URL=ws://100.81.175.3:8002
# ── WebSocket / Raspberry ──────────────────────────────────────────────────────
# Intervalle (ms) entre deux envois batch vers les chariots
CART_FLUSH_MS=250

