# .env.example à commiter sur github, à copier en .env et à remplir avec les bonnes valeurs (notamment les secrets) pour lancer le projet en local. Ne pas commiter de secrets réels sur github, même dans un projet étudiant.
# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=plume
PG_USER=postgres
PG_PASSWORD= XXXX

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Changer ces valeurs en production (chaîne aléatoire longue)
JWT_SECRET=changer-en-prod
CART_SECRET=changer-en-prod

# ── WebSocket / Raspberry ──────────────────────────────────────────────────────
# Intervalle (ms) entre deux envois batch vers les chariots (1000 recommandé)
CART_FLUSH_MS=1000

# URL du serveur utilisée par le client Raspberry en local
SERVER_URL=http://localhost:3000

# ── Electron ──────────────────────────────────────────────────────────────────
# Chemin de démarrage de l'app Electron: / pour l'utilisateur
ELECTRON_ENTRY_PATH=/
