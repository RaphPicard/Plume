# .env.example à commiter sur github, à copier en .env et à remplir avec les bonnes valeurs (notamment les secrets) pour lancer le projet en local. Ne pas commiter de secrets réels sur github, même dans un projet étudiant.
# ── PostgreSQL ─────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DB=plume
PG_USER=postgres
PG_PASSWORD= XXXX

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth ───────────────────────────────────────────────────────────────────────
# Changer ces valeurs en production (chaîne aléatoire longue)
JWT_SECRET=changer-en-prod
CART_SECRET=changer-en-prod

# ── Suivi autonome (caméra) ────────────────────────────────────────────────────
# Secret partagé entre le serveur et le serveur caméra pour s'authentifier sur ws://<backend>:3000/data
CAMERA_SECRET=changer-en-prod
CAMERA_WS_URL=ws://100.xx.xx.xx:port #pc de julos (caméra ws pour le suivi autonome) — à changer en prod (ip publique du serveur ou nom de domaine)

# ── WebSocket / Raspberry ──────────────────────────────────────────────────────
# Intervalle (ms) entre deux envois batch vers les chariots
CART_FLUSH_MS=250

# URL du serveur utilisée par le client Raspberry en local
SERVER_URL=http://localhost:3000

# ── Electron ──────────────────────────────────────────────────────────────────
# Chemin de démarrage de l'app Electron: / pour l'utilisateur
ELECTRON_ENTRY_PATH=/
